{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "types": ["@webgpu/types"],
    "noEmit": true
  },
  "include": ["web", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "bench", "target", "pkg"]
}
